# ============================================
# 基本設定（必填）
# ============================================

# 你的 Blogger Blog ID
# 取得方式：進入 Blogger 後台，網址列會顯示 blogger.com/blog/posts/[這串數字就是 BLOG_ID]
BLOGGER_BLOG_ID=

# Google API Key（必填）
# 取得方式：https://console.cloud.google.com/ → APIs & Services → Credentials → Create API Key
# 記得啟用 Blogger API v3
GOOGLE_API_KEY=

# ============================================
# OAuth 設定（選填，只有更新標籤時需要）
# ============================================
# 如果只想「分析標籤」和「預覽建議」，上面兩個就夠了！
# 如果要「批量更新標籤」，才需要設定下面的 OAuth

# Google OAuth 2.0 憑證
# 取得方式：https://console.cloud.google.com/ → APIs & Services → Credentials 
# → Create OAuth 2.0 Client ID → Web application
# 授權重新導向 URI 填入：http://localhost:3000/oauth2callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# ============================================
# AI 設定
# ============================================

# AI 提供者 (gemini 或 openai)
AI_PROVIDER=gemini

# Google Gemini API Key（推薦，免費額度較高）
# 取得方式：https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI API Key（可選）
OPENAI_API_KEY=

# ============================================
# 標籤設定
# ============================================

# 每篇文章最多幾個標籤
MAX_TAGS_PER_POST=5

# 最低信心度門檻（0.0-1.0，建議 0.6-0.8）
MIN_TAG_CONFIDENCE=0.6

# ============================================
# 執行設定
# ============================================

# 批次處理大小（避免 API 超限）
BATCH_SIZE=10

# 測試模式（true=只預覽不更新，false=真的更新）
DRY_RUN=false
